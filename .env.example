# --- Frontend (safe to expose in the browser bundle) ---
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id

# --- Server-side scripts only (NEVER commit the real key or ship it to the frontend) ---
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-server-api-key

# Email notifications (optional) — https://resend.com free tier
RESEND_API_KEY=
# Resend sandbox only delivers to the account owner's address; set it here to
# redirect all demo emails there. Remove once a domain is verified on Resend.
EMAIL_DEMO_REDIRECT=
